# Public site URL (already used elsewhere)
NEXT_PUBLIC_SITE_URL=https://softsolutions.co.ke

# SMTP configuration for the contact form (/api/contact).
# These power nodemailer — set them in your hosting provider's env settings.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Optional. Defaults to SMTP_USER if unset. Must be an address you're
# authorised to send "From".
SMTP_FROM=

# Optional. Where contact enquiries are delivered.
# Defaults to communications@softsolutions.co.ke.
# CONTACT_TO=

# --- Analytics & search-engine verification (all public NEXT_PUBLIC_*) ---

# Google Analytics 4 Measurement ID (looks like G-XXXXXXXXXX). Leave blank to
# disable analytics. Google Analytics → Admin → Data streams.
NEXT_PUBLIC_GA_ID=

# Google Search Console verification token — the `content` value of the
# `<meta name="google-site-verification">` tag from the "HTML tag" method.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools verification token (optional) — the `content` value of
# the `<meta name="msvalidate.01">` tag.
NEXT_PUBLIC_BING_SITE_VERIFICATION=
